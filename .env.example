# LLM provider: groq | gemini | openrouter | mock
LLM_PROVIDER=mock
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
LLM_MODEL=

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Paths
CATALOG_PATH=catalog/data/shl_catalog.json
VECTORSTORE_PATH=vectorstore/faiss.index
VECTORSTORE_META_PATH=vectorstore/metadata.json

# Retrieval
RETRIEVAL_TOP_K=20
RERANK_TOP_K=10
MIN_RETRIEVAL_SCORE=0.25

# Agent
MAX_CONVERSATION_TURNS=8
LOG_LEVEL=INFO
